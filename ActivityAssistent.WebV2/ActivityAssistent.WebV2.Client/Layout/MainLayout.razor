@inherits LayoutComponentBase
@using MudBlazor
@using ActivityAssistent.WebV2.Client.Services
@using ActivityAssistent.Shared.Dtos.Identity
@inject IThemeService ThemeService
@using ActivityAssistent.WebV2.Client.Interfaces.Identity

@inject IAuthService AuthService
@inject IDialogService DialogService
@using ActivityAssistent.WebV2.Client.Pages

<MudThemeProvider Theme="@ActivityAssistantTheme" IsDarkMode="@IsDarkMode" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />


<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" Class="mr-2" />
        <MudText Typo="Typo.h6" Color="Color.Primary">Activity Assistant</MudText>
        <MudSpacer />

        @* Blazor kijkt nu zelf of er een geldige token is *@
        <AuthorizeView Context="AuthContext">
            <Authorized>
                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Class="mx-2">
                    <ActivatorContent>
                        <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium">
                            @* Aangepast naar AuthContext en we geven de naam mee *@
                            @GetUserInitial(AuthContext.User.Identity?.Name)
                        </MudAvatar>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="px-4 py-2">
                            @* Aangepast naar AuthContext *@
                            <MudText Typo="Typo.body2"><b>@AuthContext.User.Identity?.Name</b></MudText>
                        </div>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings">Account Settings</MudMenuItem>
                        <MudMenuItem Icon="@Icons.Material.Filled.Settings">Account Settings</MudMenuItem>

                        <form action="/auth/logout" method="post">
                            <AntiforgeryToken />
                            <button type="submit" style="all: unset; width: 100%; cursor: pointer;">
                                <MudMenuItem Icon="@Icons.Material.Filled.Logout" IconColor="Color.Error">
                                    Logout
                                </MudMenuItem>
                            </button>
                        </form>
                    </ChildContent>
                </MudMenu>
            </Authorized>
            <NotAuthorized>
                <MudButton Variant="Variant.Text"
                           Color="Color.Inherit"
                           StartIcon="@Icons.Material.Filled.Login"
                           Href="/login">
                    Login
                </MudButton>
            </NotAuthorized>
        </AuthorizeView>

        <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" OnClick="ToggleDarkMode" Color="Color.Inherit" />
    </MudAppBar>

    <MudDrawer @bind-Open="IsDrawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/SalesConversation/" Icon="@Icons.Material.Filled.Handshake">Sales conversations</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool IsDarkMode = true;
    private bool IsDrawerOpen = true;

    private MudTheme ActivityAssistantTheme = new MudTheme()
    {
        PaletteDark = new PaletteDark()
        {
            Primary = "#1DB954",
            PrimaryDarken = "#1ed760",
            Secondary = "#1A3A52",
            Tertiary = "#1A1A1E",
            Background = "#0D1F2D",
            Surface = "#1A3A52",
            AppbarBackground = "#0D1F2D",
            TextPrimary = "#E0E0E0",
            TextSecondary = "#A9A9A9"
        },
        PaletteLight = new PaletteLight()
        {
            Primary = "#1DB954",
            Secondary = "#1A3A52",
            Background = "#F5F5F5",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            TextPrimary = "#191414",
            TextSecondary = "#545454"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        // Alleen Theme laden. Auth wordt nu door Blazor geregeld!
        IsDarkMode = await ThemeService.IsDarkModeAsync();
    }

    public async Task ToggleDarkMode()
    {
        IsDarkMode = !IsDarkMode;
        await ThemeService.SetDarkModeAsync(IsDarkMode);
        StateHasChanged();
    }

    private void ToggleDrawer()
    {
        IsDrawerOpen = !IsDrawerOpen;
    }

   
    // Nu accepteert de functie netjes de FullName string
    private string GetUserInitial(string? FullName)
    {
        if (!string.IsNullOrWhiteSpace(FullName))
        {
            return FullName.Substring(0, 1).ToUpper();
        }
        return "U";
    }
}
