@page "/"
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Interfaces.Identity
@using ActivityAssistent.Shared.Dtos
@using MudBlazor
@inject IAuthService AuthService

<PageTitle>Dashboard - ActivityAssistent</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h3" GutterBottom="true" Class="mb-6">Sales Dashboard</MudText>

    @if (UserProfile == null && !IsError)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
    }
    else if (IsError)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">
            Could not load dashboard data. Please check your connection.
        </MudAlert>
    }
    else
    {
        <MudGrid>
            <!-- Welkomstkaart -->
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="rounded-lg">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h5">Welcome back!</MudText>
                            <MudText Typo="Typo.subtitle1" Color="Color.Primary">@UserProfile?.FullName</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Default" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2">Role: @UserProfile?.JobTitle</MudText>
                        <MudText Typo="Typo.body2">ID: @UserProfile?.UserId</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Snelle Acties (Placeholders voor je kernfunctionaliteit) -->
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="4" Class="rounded-lg border-l-4 border-solid mud-border-primary">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Quick Actions</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   FullWidth="true" 
                                   StartIcon="@Icons.Material.Filled.Mic"
                                   Class="mb-2">
                            New Recording
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Statistiekenoverzicht (Mock data voor nu) -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-4 rounded-lg" Elevation="4">
                    <MudText Typo="Typo.h6" Class="mb-2">Today's Summary</MudText>
                    <MudDivider Class="mb-4" />
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.body1"><b>0</b> Conversations Recorded</MudText>
                        <MudText Typo="Typo.body1"><b>0</b> Action Points Pending</MudText>
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</MudContainer>

@code {
    // PascalCase variabelen
    private UserProfileDto? UserProfile;
    private bool IsError = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // De WebAuthService maakt een HTTP-call naar je API Controller, 
            // die vervolgens via de Service en Infrastructure laag data uit Dataverse haalt.
            UserProfile = await AuthService.GetCurrentProfileAsync();
        }
        catch (Exception)
        {
            IsError = true;
        }
    }
}