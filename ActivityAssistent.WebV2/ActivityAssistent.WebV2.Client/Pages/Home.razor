@page "/"
@* Deze tag beveiligt de pagina. Gasten worden hier nu geweigerd. *@
@using Microsoft.AspNetCore.Authorization
@using ActivityAssistent.WebV2
@attribute [Authorize]
@inject AuthenticationStateProvider AuthStateProvider
@using ActivityAssistent.Shared.Dtos
@using MudBlazor

<PageTitle>Dashboard - ActivityAssistent</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
    <MudText Typo="Typo.h3" GutterBottom="true" Class="mb-6">Sales Dashboard</MudText>

    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="4" Class="rounded-lg">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h5">Welcome back!</MudText>
                        <MudText Typo="Typo.subtitle1" Color="Color.Primary">@UserName</MudText>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Default" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2">Your sales overview and action points are loading...</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

    </MudGrid>
</MudContainer>

@code {
    private string UserName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += HandleAuthenticationStateChanged;
        await LoadUserState();
    }

    private async Task LoadUserState()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = state.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            UserName = user.Identity.Name ?? "Sales Professional";
            StateHasChanged();
        }
    }

    private void HandleAuthenticationStateChanged(Task<AuthenticationState> task)
    {
        InvokeAsync(LoadUserState);
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= HandleAuthenticationStateChanged;
    }
}