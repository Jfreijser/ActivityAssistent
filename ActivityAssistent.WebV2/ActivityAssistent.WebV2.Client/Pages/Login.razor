@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Interfaces.Identity
@inject IAuthService AuthService


<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h5" Align="Align.Center" Color="Color.Primary" Class="mb-4">
            SalesAssistant Login
        </MudText>
        
        <MudTextField @bind-Value="Email" Label="E-mailadres" Variant="Variant.Outlined" Class="mb-4" />
        <MudTextField @bind-Value="Password" Label="Wachtwoord" Variant="Variant.Outlined" InputType="InputType.Password" Class="mb-4" />
        
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="my-2">@ErrorMessage</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Annuleren</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleLogin" Disabled="@IsLoading">
            @if (IsLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
            }
            else
            {

                <MudText>Inloggen</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private string Email { get; set; } = string.Empty;
    private string Password { get; set; } = string.Empty;
    private string ErrorMessage { get; set; } = string.Empty;
    private bool IsLoading { get; set; } = false;

    private void Cancel() => MudDialog.Cancel();

    private async Task HandleLogin()
    {
        ErrorMessage = string.Empty;
        IsLoading = true;
        try
        {
            var result = await AuthService.LoginAsync(new LoginCredentialsDto { Email = Email, Password = Password }, default);
            // In plaats van navigeren, sluiten we de dialoog met een "Ok" resultaat
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            ErrorMessage = "Fout: " + ex.Message;
        }
        finally { IsLoading = false; }
    }
}