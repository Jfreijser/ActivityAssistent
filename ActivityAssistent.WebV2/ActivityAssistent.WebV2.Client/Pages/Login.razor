@page "/login"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="4" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Color="Color.Primary" Class="mb-6">
            Login
        </MudText>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">@ErrorMessage</MudAlert>
        }

        <form action="/auth/login" method="post">

            <AntiforgeryToken />

            <MudTextField T="string"
                          Label="E-mailadres"
                          Variant="Variant.Outlined"
                          Class="mb-4"
                          name="Email"
                          Required="true" />

            <MudTextField T="string"
                          Label="Wachtwoord"
                          Variant="Variant.Outlined"
                          InputType="InputType.Password"
                          Class="mb-6"
                          name="Password"
                          Required="true" />

            <MudButton FullWidth="true"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Size="Size.Large"
                       ButtonType="ButtonType.Submit">
                <MudText>Inloggen</MudText>
            </MudButton>
        </form>
    </MudPaper>
</MudContainer>

@code {
    // Blazor pikt automatisch de '?error=...' uit de URL op dankzij deze tag
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorQuery { get; set; }

    // Bepaal de foutmelding op basis van de URL parameter
    private string ErrorMessage => ErrorQuery == "InvalidCredentials"
        ? "Inloggen mislukt. Controleer je gegevens."
        : string.Empty;
}