@page "/SalesConversation/Create"
@using MudBlazor
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Dtos.Companies
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.WebV2.Client.Pages.Companies
@using ActivityAssistent.WebV2.Client.Interfaces.companies
@using ActivityAssistent.WebV2.Client.Interfaces.Conversations
@inject IConversationService ConversationService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICompanyService CompanyService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Elevation="4" Class="pa-6" Style="border-radius: 16px;">

        @* Header met terug-knop *@
        <div class="d-flex align-center mb-6">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => NavManager.NavigateTo("/SalesConversation/SalesConversationIndex"))"
                           Class="mr-2" />
            <MudText Typo="Typo.h5" Color="Color.Primary"><b>Gesprek Voorbereiden</b></MudText>
        </div>

        <MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">
            Vul de basisgegevens in zodat je de opname direct kunt starten zodra het gesprek begint.
        </MudText>

        <MudForm @ref="Form" @bind-IsValid="@IsFormValid">
            <MudGrid Spacing="3">

                @* 1. Onderwerp / Titel *@
                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="Onderwerp van het gesprek"
                                  Required="true"
                                  RequiredError="Geef het gesprek een herkenbare titel"
                                  Placeholder="bijv. Kennismaking met Jansen B.V."
                                  Variant="Variant.Outlined"
                                  @bind-Value="Conversation.Title" />
                </MudItem>

                @* 2. Klant Selectie (Lookup naar Account/Contact) *@
                <MudItem xs="12">
                    <MudSelect T="Guid"
                               Label="Klant / Bedrijf"
                               Required="true"
                               RequiredError="Selecteer een klant"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter"
                               @bind-Value="Conversation.CompanyId">

                        <MudSelectItem Value="@(Guid.Empty)">-- Selecteer een Klant --</MudSelectItem>

                        @foreach (var Customer in Customers)
                        {
                            <MudSelectItem Value="@Customer.CompanyId">@Customer.Name</MudSelectItem>
                        }

                        @* Vaste nep-ID's om de oneindige loop te voorkomen! *@
                        <MudSelectItem Value="@(new Guid("11111111-1111-1111-1111-111111111111"))">Klant A (Demo)</MudSelectItem>
                        <MudSelectItem Value="@(new Guid("22222222-2222-2222-2222-222222222222"))">Klant B (Demo)</MudSelectItem>
                    </MudSelect>

                    <div class="d-flex justify-end mt-1">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   Size="Size.Small"
                                   OnClick="OpenCreateCustomerDialog">
                            Nieuwe klant aanmaken
                        </MudButton>
                    </div>
                </MudItem>

                @* 3. Datum en Tijd *@
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Datum afspraak"
                                   @bind-Date="SelectedDate"
                                   Variant="Variant.Outlined"
                                   Editable="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTimePicker Label="Tijdstip"
                                   @bind-Time="SelectedTime"
                                   Variant="Variant.Outlined"
                                   Editable="true" />
                </MudItem>

                @* 4. Medewerker (Read-only, want jij bent het) *@
                <MudItem xs="12">
                    <MudTextField T="string"
                                  Label="Verkoopmedewerker"
                                  ReadOnly="true"
                                  Value="@UserProfile?.FullName"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Person" />
                </MudItem>

                @* Actie Knoppen *@
                <MudItem xs="12" Class="d-flex justify-end mt-4">
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               OnClick="@(() => NavManager.NavigateTo("/SalesConversation/SalesConversationIndex"))"
                               Class="mr-2">
                        Annuleren
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="HandleSave"
                               Disabled="@(!IsFormValid || IsSaving)"
                               Size="Size.Large">
                        @if (IsSaving)
                        {
                            <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                            <MudText Class="ms-2">Opslaan...</MudText>
                        }
                        else
                        {
                            <MudText>Opslaan & Klaarzetten</MudText>
                        }
                    </MudButton>
                </MudItem>

            </MudGrid>
        </MudForm>
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    public UserProfileDto UserProfile { get; set; } = new();
    private bool IsSaving;
    private MudForm Form;
    private bool IsFormValid;

    private List<CompanyNames> Customers = new List<CompanyNames>();
    private CreateConversationDto Conversation = new();
    private CancellationTokenSource TokenSource { get; set; } = new();

    // Helpers voor de Date/Time pickers
    private DateTime? SelectedDate = DateTime.Today;
    private TimeSpan? SelectedTime = DateTime.Now.TimeOfDay;

    protected override async Task OnInitializedAsync()
    {
        try
        {

            await GetCompanies();

            // Koppel automatisch de medewerker ID aan de nieuwe opname, veilig genest
            if (UserProfile != null && UserProfile.UserId.HasValue)
            {
                Conversation.SalesUserId = UserProfile.UserId.Value;
            }
        }
        catch (Exception Ex)
        {
            // Vangt een eventuele stille crash op en toont hem in je Visual Studio Output!
            Console.WriteLine($"CRASH TIJDENS LADEN PAGINA: {Ex.Message}");
        }
    }

    private async Task GetCompanies()
    {
        Customers = await CompanyService.GetCustomerAsync(TokenSource.Token);
    }

    private async Task HandleSave()
    {
        if (IsFormValid)
        {
            try
            {
                IsSaving = true; 

                if (SelectedDate.HasValue && SelectedTime.HasValue)
                {
                    Conversation.MeetingDate = SelectedDate.Value.Add(SelectedTime.Value);
                }

                var Result = await ConversationService.CreateConversationAsync(Conversation, TokenSource.Token);

                if (Result.ConversationId != Guid.Empty)
                {

                    Snackbar.Add("Gesprek succesvol klaargezet!", Severity.Success);

            
                    NavManager.NavigateTo($"/SalesConversation/Detail/{Result.ConversationId}");

                    
                }
        }
        catch (TaskCanceledException)
        {
           
            Console.WriteLine("Het opslaan is geannuleerd (bijv. door een time-out of navigatie).");
            Snackbar.Add("Het opslaan duurde te lang of is afgebroken.", Severity.Warning);
        }
        catch (Exception Ex)
        {
            // Vangt alle andere fouten op (zoals een onbereikbare database)
            Console.WriteLine($"Fout tijdens opslaan: {Ex.Message}");
            Snackbar.Add("Er ging iets mis bij het aanmaken van het gesprek.", Severity.Error);
        }
        finally
        {
           
            IsSaving = false;
        }
            
        }
    }

    private async Task OpenCreateCustomerDialog()
    {
        var Options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = true // Voorkomt per ongeluk sluiten naast het venster
        };

        // 'CreateCustomerDialog' is de component (het formulier) die in de pop-up verschijnt
        var Dialog = await DialogService.ShowAsync<CreateCustomerDialog>("Nieuwe Klant Toevoegen", Options);
        var Result = await Dialog.Result;

        // Controleer of de gebruiker niet op annuleren heeft gedrukt
        if (!Result.Canceled && Result.Data is true)
        {
            // 1. Ververs hier je lokale lijst met klanten door je REST API opnieuw aan te roepen.
            await GetCompanies();


            // Geef de UI een seintje dat de geselecteerde waarde is aangepast
            StateHasChanged();

            Snackbar.Add("New customer has been added!", Severity.Success);
        }
    }

    public void Dispose()
    {
        TokenSource.Cancel();
        TokenSource.Dispose();
    }
}