@page "/SalesConversation/Summary/{ConversationId:guid}"
@using ActivityAssistent.Shared.Dtos.Ai
@using ActivityAssistent.WebV2.Client.Interfaces.Ai
@using MudBlazor
@inject IAiMeetingAnalyzer AiMeetingAnalyzer

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
	<MudText Typo="Typo.h4" Color="Color.Primary">Summary</MudText>
	<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
		Overview of the AI summary for this conversation.
	</MudText>

	@if (IsLoading)
	{
		<MudPaper Elevation="2" Class="pa-6 d-flex align-center justify-center">
			<MudProgressCircular Color="Color.Primary" Indeterminate="true" />
		</MudPaper>
	}
	else if (!string.IsNullOrWhiteSpace(ErrorMessage))
	{
		<MudAlert Severity="Severity.Error" Variant="Variant.Filled" Class="my-4">
			@ErrorMessage
		</MudAlert>
	}
	else if (AnalysisStates.Count == 0)
	{
		<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="my-4">
			No recordings or AI summaries are available yet.
		</MudAlert>
	}
	else
	{
		<MudStack Spacing="3">
			@foreach (var item in AnalysisStates)
			{
				<MudPaper Elevation="2" Class="pa-4">
					<MudText Typo="Typo.subtitle1">AI Summary</MudText>
					<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
						@if (string.IsNullOrWhiteSpace(item.AiSummary))
						{
							<span>No summary available.</span>
						}
						else
						{
							@item.AiSummary
						}
					</MudText>

					<MudDivider Class="my-3" />

					<MudText Typo="Typo.subtitle1">Recording</MudText>
					<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
						@if (string.IsNullOrWhiteSpace(item.FilePath))
						{
							<span>No recording path available.</span>
						}
						else
						{
							@item.FilePath
						}
					</MudText>
					@if (!string.IsNullOrWhiteSpace(item.FilePath))
					{
						<audio controls src="@item.FilePath" class="mt-2 w-100"></audio>
					}
				</MudPaper>
			}
		</MudStack>
	}
</MudContainer>

@code {
	[Parameter]
	public Guid ConversationId { get; set; }

	private bool IsLoading { get; set; } = true;
	private string ErrorMessage { get; set; } = string.Empty;
	private List<AiAnalysisStateRecord> AnalysisStates { get; set; } = new();
	private CancellationTokenSource TokenSource { get; set; } = new();

	protected override async Task OnInitializedAsync()
	{
		try
		{
			IsLoading = true;
			AnalysisStates = (await AiMeetingAnalyzer.GetAnalysisStateByConversationIdAsync(ConversationId, TokenSource.Token)).ToList();
		}
		catch (Exception ex)
		{
			ErrorMessage = "Failed to load AI summaries and recordings.";
			Console.WriteLine($"Error loading analysis state: {ex.Message}");
		}
		finally
		{
			IsLoading = false;
		}
	}
}
