@page "/SalesConversation/Record"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
	<MudText Typo="Typo.h4" Color="Color.Primary">Gesprek opnemen</MudText>
	<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
		Start en stop een opname en sla het gesprek op voor latere analyse.
	</MudText>

	<MudPaper Elevation="2" Class="pa-4">
		<MudText Typo="Typo.subtitle1">Opnamebediening</MudText>
		<MudText Typo="Typo.body2" Color="Color.Secondary">
			Hier komt de audio-opname en opslagfunctionaliteit.
		</MudText>
		<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">
			Start opname
		</MudButton>
	</MudPaper>
</MudContainer>
