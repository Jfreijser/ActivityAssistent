@page "/SalesConversation/"
@using MudBlazor
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Enums
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.WebV2.Client.Interfaces.Conversations
@inject IConversationService ConversationService
@inject NavigationManager NavigationManager
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">

    @* SECTION 1: Page Header *@
    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudItem>
            <MudText Typo="Typo.h4" Color="Color.Primary">Sales Conversations</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Overview of recorded sales conversations and AI analyses.
            </MudText>
        </MudItem>
        <MudItem>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.AddIcCall"
                       Size="Size.Large"
                       OnClick="NavigateToCreatePage">
                Create a new conversation
            </MudButton>
        </MudItem>
    </MudGrid>

    @* SECTION 2: KPI / Status Cards *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Conversations</MudText>
                <MudText Typo="Typo.h4">@Conversations.Count</MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle2" Color="Color.Warning">Processing by AI</MudText>
                <MudText Typo="Typo.h4">@Conversations.Count(c => c.Status == ConversationStatus.Processing)</MudText>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudCard Elevation="2" Class="pa-4">
                <MudText Typo="Typo.subtitle2" Color="Color.Success">Completed Analyses</MudText>
                <MudText Typo="Typo.h4">@Conversations.Count(c => c.Status == ConversationStatus.Completed)</MudText>
            </MudCard>
        </MudItem>
    </MudGrid>

    @* SECTION 3: Filters & Search *@
    <MudPaper Elevation="2" Class="pa-4 mb-6">
        <MudGrid AlignItems="AlignItems.Center">
            <MudItem xs="12" sm="6" md="4">
                <MudTextField @bind-Value="SearchTerm"
                              Placeholder="Search by customer or subject..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="3" md="3">
                <MudSelect @bind-Value="SelectedStatus" T="string" Label="Status Filter">
                    <MudSelectItem Value="@("All")">All statuses</MudSelectItem>
                    <MudSelectItem Value="@(ConversationStatus.Scheduled.ToString())">Scheduled</MudSelectItem>
                    <MudSelectItem Value="@(ConversationStatus.Recording.ToString())">Recording</MudSelectItem>
                    <MudSelectItem Value="@(ConversationStatus.Processing.ToString())">Processing...</MudSelectItem>
                    <MudSelectItem Value="@(ConversationStatus.Completed.ToString())">Completed</MudSelectItem>
                    <MudSelectItem Value="@(ConversationStatus.Failed.ToString())">Failed</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" md="2">
                <MudDatePicker @bind-Date="FilterDate" Label="Date from" Editable="true" SaveOnBlur="true" />
            </MudItem>
            <MudItem xs="12" sm="12" md="3" Class="d-flex justify-sm-end">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="ResetFilters"
                           Class="mt-2">
                    Clear Filters
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* SECTION 4: Data Table *@
    <MudPaper Elevation="2">
        @if (IsLoadingConversations)
        {
            <div class="d-flex justify-center align-center pa-12">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Class="ml-4">Loading conversations...</MudText>
            </div>
        }
        else
        {
            <MudTable Items="FilteredConversations" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
                <HeaderContent>
                    <MudTh>Date</MudTh>
                    <MudTh>Customer / Subject</MudTh>
                    <MudTh>Employee</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Date">@context.MeetingDate.ToString("dd-MM-yyyy HH:mm")</MudTd>
                    <MudTd DataLabel="Customer / Subject">@context.CompanyName</MudTd>
                    <MudTd DataLabel="Employee">@UserProfile?.FullName</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="GetStatusColor(context.Status)" Size="Size.Small">
                            @GetStatusText(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="() => NavigateToDetail(context.ConversationId)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager InfoFormat="{first_item}-{last_item} of {all_items}" RowsPerPageString="Rows per page:" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    [CascadingParameter]
    public UserProfileDto? UserProfile { get; set; }

    private string SearchTerm { get; set; } = string.Empty;
    private string SelectedStatus { get; set; } = "All";
    private DateTime? FilterDate { get; set; }
    private bool IsLoadingConversations { get; set; } = false;

    private List<ConversationDto> Conversations { get; set; } = new List<ConversationDto>();
    private CancellationTokenSource TokenSource { get; set; } = new();

    private IEnumerable<ConversationDto> FilteredConversations
    {
        get
        {
            var query = Conversations.AsEnumerable();

            // Filter 1: Search term (Customer/Company name)
            if (!string.IsNullOrWhiteSpace(SearchTerm))
            {
                query = query.Where(c => c.CompanyName != null &&
                                         c.CompanyName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));
            }

            // Filter 2: Status Enum comparison as String
            if (SelectedStatus != "All")
            {
                query = query.Where(c => c.Status.ToString() == SelectedStatus);
            }

            // Filter 3: Meeting Date comparison
            if (FilterDate.HasValue)
            {
                query = query.Where(c => c.MeetingDate.Date >= FilterDate.Value.Date);
            }

            return query;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadConversationsAsync();
    }

    private async Task LoadConversationsAsync()
    {
        IsLoadingConversations = true;
        try
        {
            var result = await ConversationService.GetAllAsync(TokenSource.Token);
            Conversations = result?.ToList() ?? new List<ConversationDto>();
        }
        catch
        {
            // Optional: Add Snackbar logging
        }
        finally
        {
            IsLoadingConversations = false;
        }
    }

    private Color GetStatusColor(ConversationStatus Status)
    {
        return Status switch
        {
            ConversationStatus.Scheduled => Color.Info,
            ConversationStatus.Recording => Color.Secondary,
            ConversationStatus.Processing => Color.Warning,
            ConversationStatus.Completed => Color.Success,
            ConversationStatus.Failed => Color.Error,
            _ => Color.Default
        };
    }

    private string GetStatusText(ConversationStatus Status)
    {
        return Status switch
        {
            ConversationStatus.Scheduled => "Scheduled",
            ConversationStatus.Recording => "Recording",
            ConversationStatus.Processing => "Processing...",
            ConversationStatus.Completed => "Completed",
            ConversationStatus.Failed => "Failed",
            _ => "Unknown"
        };
    }

    private void NavigateToCreatePage()
    {
        NavigationManager.NavigateTo("/SalesConversation/Create");
    }

    private void NavigateToDetail(Guid ConversationId)
    {
        NavigationManager.NavigateTo($"/SalesConversation/Detail/{ConversationId}");
    }

    private void ResetFilters()
    {
        SearchTerm = string.Empty;
        SelectedStatus = "All";
        FilterDate = null;
    }

    public void Dispose()
    {
        TokenSource.Cancel();
        TokenSource.Dispose();
    }
}