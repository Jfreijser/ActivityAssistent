@page "/SalesConversation/TeamActionPoints"
@using MudBlazor

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">
	<MudText Typo="Typo.h4" Color="Color.Primary">Teamactiepunten</MudText>
	<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
		Overzicht van taken en statussen van het team.
	</MudText>

	<MudPaper Elevation="2" Class="pa-4">
		<MudText Typo="Typo.subtitle1">Teamtaken</MudText>
		<MudText Typo="Typo.body2" Color="Color.Secondary">
			Hier komt een overzicht van teamtaken en voortgang.
		</MudText>
	</MudPaper>
</MudContainer>
