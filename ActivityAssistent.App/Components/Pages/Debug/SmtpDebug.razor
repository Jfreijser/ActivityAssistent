@page "/debug/smtp"
@using Microsoft.Maui.Storage
@using MudBlazor
@inject ISnackbar Snackbar

<PageTitle>SMTP Debug</PageTitle>

@if (IsDebug)
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-6">
        <MudText Typo="Typo.h5" Color="Color.Primary">SMTP Debug Settings</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            Store SMTP settings locally in SecureStorage (developer-only).
        </MudText>

        <MudPaper Elevation="2" Class="pa-4">
            <MudTextField Label="SMTP host" @bind-Value="_host" Variant="Variant.Outlined" />
            <MudTextField Label="SMTP port" @bind-Value="_port" Variant="Variant.Outlined" Class="mt-2" />
            <MudTextField Label="SMTP user" @bind-Value="_user" Variant="Variant.Outlined" Class="mt-2" />
            <MudTextField Label="SMTP password" @bind-Value="_pass" Variant="Variant.Outlined" InputType="InputType.Password" Class="mt-2" />
            <MudTextField Label="Sender email" @bind-Value="_sender" Variant="Variant.Outlined" Class="mt-2" />

            <MudStack Row="true" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync">
                    Save to SecureStorage
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="LoadAsync">
                    Load from SecureStorage
                </MudButton>
                <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="ClearAsync">
                    Clear
                </MudButton>
            </MudStack>
        </MudPaper>
    </MudContainer>
}
else
{
    <MudContainer MaxWidth="MaxWidth.Small" Class="mt-6">
        <MudText Typo="Typo.body1">Debug-only page.</MudText>
    </MudContainer>
}

@code {
#if DEBUG
    private const bool IsDebug = true;
#else
    private const bool IsDebug = false;
#endif

    private const string SmtpHostKey = "smtp_host";
    private const string SmtpUserKey = "smtp_user";
    private const string SmtpPassKey = "smtp_pass";
    private const string SmtpSenderKey = "smtp_sender";
    private const string SmtpPortKey = "smtp_port";

    private string _host = string.Empty;
    private string _port = "587";
    private string _user = string.Empty;
    private string _pass = string.Empty;
    private string _sender = string.Empty;

    private async Task SaveAsync()
    {
        await SecureStorage.SetAsync(SmtpHostKey, _host ?? string.Empty);
        await SecureStorage.SetAsync(SmtpPortKey, _port ?? string.Empty);
        await SecureStorage.SetAsync(SmtpUserKey, _user ?? string.Empty);
        await SecureStorage.SetAsync(SmtpPassKey, _pass ?? string.Empty);
        await SecureStorage.SetAsync(SmtpSenderKey, _sender ?? string.Empty);

        Snackbar.Add("SMTP settings saved locally.", Severity.Success);
    }

    private async Task LoadAsync()
    {
        _host = await SecureStorage.GetAsync(SmtpHostKey) ?? string.Empty;
        _port = await SecureStorage.GetAsync(SmtpPortKey) ?? "587";
        _user = await SecureStorage.GetAsync(SmtpUserKey) ?? string.Empty;
        _pass = await SecureStorage.GetAsync(SmtpPassKey) ?? string.Empty;
        _sender = await SecureStorage.GetAsync(SmtpSenderKey) ?? string.Empty;

        Snackbar.Add("SMTP settings loaded.", Severity.Info);
    }

    private Task ClearAsync()
    {
        SecureStorage.Remove(SmtpHostKey);
        SecureStorage.Remove(SmtpPortKey);
        SecureStorage.Remove(SmtpUserKey);
        SecureStorage.Remove(SmtpPassKey);
        SecureStorage.Remove(SmtpSenderKey);

        Snackbar.Add("SMTP settings cleared.", Severity.Warning);
        return Task.CompletedTask;
    }
}