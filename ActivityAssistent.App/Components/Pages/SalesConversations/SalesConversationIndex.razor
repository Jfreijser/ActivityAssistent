@page "/SalesConversation/"
@using MudBlazor
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.App.Interfaces.companies
@using ActivityAssistent.Shared.Enums
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.App.Components.Pages.Companies
@using ActivityAssistent.App.Interfaces.Conversations
@inject IConversationService ConversationService
@inject ICompanyService CompanyService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@implements IDisposable
<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudItem>
            <MudText Typo="Typo.h4" Color="Color.Primary">Sales Conversations</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Select a company to view its recorded sales conversations and AI analyses.
            </MudText>
        </MudItem>
        <MudItem>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OpenCreateCustomerDialog">
                Add Customer
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Summarize"
                       OnClick="NavigateToSummaries"
                       Class="ms-2">
                Summaries
            </MudButton>
        </MudItem>
    </MudGrid>

    <MudPaper Elevation="2" Class="pa-4">
        @if (IsLoadingConversations)
        {
            <div class="d-flex justify-center align-center pa-12">
                <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                <MudText Class="ml-4">Loading companies...</MudText>
            </div>
        }
        else
        {
            <MudTable Items="Companys"
                      T="CompanyOverviewDto"
                      Hover="true"
                      Filter="new Func<CompanyOverviewDto,bool>(FilterFunc)"
                      OnRowClick="@((args) => RowClicked(args))"
                      Elevation="0">
                <ToolBarContent>
                    <MudSpacer />
                    <MudTextField @bind-Value="searchString"
                                  Placeholder="Search by company name..."
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  IconSize="Size.Medium"
                                  Class="mt-0" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>Company Name</MudTh>
                    <MudTh>Total Conversations</MudTh>
                    <MudTh>Last Contact</MudTh>
                    <MudTh Style="text-align: right;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Company Name">@context.CompanyName</MudTd>
                    <MudTd DataLabel="Total Conversations">@context.TotalConversations</MudTd>
                    <MudTd DataLabel="Last Contact">
                        @(context.LastContactDate.HasValue ? context.LastContactDate.Value.ToString("dd-MM-yyyy HH:mm") : "No conversations yet")
                    </MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowForwardIos"
                                       Color="Color.Primary"
                                       Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager RowsPerPageString="Rows per page:" />
                </PagerContent>
            </MudTable>
        }
    </MudPaper>
</MudContainer>

@code {
    private List<CompanyOverviewDto> Companys { get; set; } = new List<CompanyOverviewDto>();
    private bool IsLoadingConversations { get; set; } = false;
    private string searchString = "";
    private CancellationTokenSource TokenSource { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        await GetCompanyOverview();
    }

    private async Task GetCompanyOverview()
    {
        IsLoadingConversations = true;
        try
        {
            var data = await CompanyService.GetCompanyOverviewAsync(TokenSource.Token);
            Companys = data ?? new List<CompanyOverviewDto>();
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load companies. Please try again later.", Severity.Error);
        }
        finally
        {
            IsLoadingConversations = false;
        }
    }

    private async Task OpenCreateCustomerDialog()
    {
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            BackdropClick = true
        };

        var dialog = await DialogService.ShowAsync<CreateCustomerDialog>("Add New Customer", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is true)
        {
            await GetCompanyOverview();
            Snackbar.Add("New customer has been added!", Severity.Success);
        }
    }

    // Navigate to the detail page within the SalesConversation structure
    private void RowClicked(TableRowClickEventArgs<CompanyOverviewDto> args)
    {
        NavigationManager.NavigateTo($"/SalesConversation/{args.Item.CompanyId}");
    }

    private void NavigateToSummaries()
    {
        NavigationManager.NavigateTo("/SalesConversation/Summaries");
    }

    // Filter function that searches on the correct property: CompanyName
    private bool FilterFunc(CompanyOverviewDto company)
    {
        if (string.IsNullOrWhiteSpace(searchString))
            return true;

        if (company.CompanyName.Contains(searchString, StringComparison.OrdinalIgnoreCase))
            return true;

        return false;
    }

    public void Dispose()
    {
        TokenSource.Cancel();
        TokenSource.Dispose();
    }
}