@using MudBlazor
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.Shared.Dtos.Identity

<MudDialog>
	<DialogContent>
		<MudForm @ref="Form" @bind-IsValid="IsFormValid">
			<MudGrid Spacing="3" Class="pa-2">
				<MudItem xs="12">
					<MudSelect T="Guid"
							   Label="Gesprek"
							   Required="true"
							   RequiredError="Selecteer een gesprek"
							   Variant="Variant.Outlined"
							   @bind-Value="SelectedConversationId">
						<MudSelectItem T="Guid" Value="@(Guid.Empty)">-- Selecteer een gesprek --</MudSelectItem>
						@foreach (var conversation in Conversations)
						{
							<MudSelectItem T="Guid" Value="@conversation.ConversationId">@conversation.Title</MudSelectItem>
						}
					</MudSelect>
				</MudItem>
				<MudItem xs="12">
					<MudTextField T="string"
								  Label="Omschrijving"
								  Required="true"
								  RequiredError="Omschrijving is verplicht"
								  Variant="Variant.Outlined"
								  @bind-Value="Model.Description" />
				</MudItem>
				<MudItem xs="12" sm="6">
					<MudDatePicker Label="Vervaldatum"
								   @bind-Date="Model.DueDate"
								   Variant="Variant.Outlined"
								   Editable="true" />
				</MudItem>
				<MudItem xs="12" sm="6">
					<MudSelect T="Guid"
							   Label="Toewijzen aan"
							   Required="true"
							   RequiredError="Selecteer een medewerker"
							   Variant="Variant.Outlined"
							  Value="Model.SelectedSalesUserId"
							   ValueChanged="OnSelectedSalesUserIdChanged"
							   ValueExpression="() => Model.SelectedSalesUserId">
						<MudSelectItem T="Guid" Value="@(Guid.Empty)">-- Selecteer een medewerker --</MudSelectItem>
						@foreach (var user in DelegationUsers)
						{
							<MudSelectItem T="Guid" Value="@user.UserId.GetValueOrDefault()">@user.FullName</MudSelectItem>
						}
					</MudSelect>
				</MudItem>
				<MudItem xs="12" sm="6" Class="d-flex align-center">
					<MudCheckBox T="bool" Label="Voltooid" @bind-Checked="Model.IsCompleted" />
				</MudItem>
			</MudGrid>

			<div class="d-flex justify-end mt-4">
				<MudButton OnClick="Cancel" Color="Color.Default" Class="mr-2">Annuleren</MudButton>
				<MudButton ButtonType="ButtonType.Button" Color="Color.Primary" Variant="Variant.Filled" OnClick="Save">
					Opslaan
				</MudButton>
			</div>
		</MudForm>
	</DialogContent>
</MudDialog>

@code {
	[CascadingParameter]
	private IMudDialogInstance MudDialog { get; set; }

	[Parameter]
	public ActionPointDialogModel Model { get; set; } = new();

	[Parameter]
	public List<UserProfileDto> DelegationUsers { get; set; } = new();

	[Parameter]
	public List<ConversationDto> Conversations { get; set; } = new();

	[Parameter]
	public Guid SelectedConversationId { get; set; }

	private MudForm Form;
	private bool IsFormValid;

	private async Task Save()
	{
		await Form.Validate();
		if (!IsFormValid)
		{
			return;
		}

		var result = new TeamActionPointDialogResult
		{
			ConversationId = SelectedConversationId,
			ActionPoint = Model
		};

		MudDialog.Close(DialogResult.Ok(result));
	}

	private void Cancel()
	{
		MudDialog.Cancel();
	}

	private void OnSelectedSalesUserIdChanged(Guid value)
	{
		Model.SelectedSalesUserId = value;
	}
}
