@page "/SalesConversation/Create"
@using MudBlazor
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Dtos.Companies
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.App.Components.Pages.Companies
@using ActivityAssistent.App.Interfaces.companies
@using ActivityAssistent.App.Interfaces.Conversations
@inject IConversationService ConversationService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ICompanyService CompanyService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
	<MudPaper Elevation="4" Class="pa-6" Style="border-radius: 16px;">

		@* Header met terug-knop *@
		<div class="d-flex align-center mb-6">
			<MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
						   OnClick="NavigateBack"
						   Class="mr-2" />
			<MudText Typo="Typo.h5" Color="Color.Primary"><b>Prepare Conversation</b></MudText>
		</div>

		<MudText Typo="Typo.body2" Class="mb-6" Color="Color.Secondary">
			Fill in the basic details so you can start recording immediately when the conversation begins.
		</MudText>

		<MudForm @ref="Form" @bind-IsValid="IsFormValid">
			<MudGrid Spacing="3">

				@* 1. Onderwerp / Titel *@
				<MudItem xs="12">
					<MudTextField T="string"
								  Label="Conversation Title"
								  Required="true"
								  RequiredError="Please provide a recognizable title"
								  Placeholder="e.g. Introduction with Jansen B.V."
								  Variant="Variant.Outlined"
								  @bind-Value="Conversation.Title" />
				</MudItem>

				@* 2. Klant Selectie (Lookup naar Account/Contact) *@
				<MudItem xs="12">
					<MudSelect T="Guid"
							   Label="Customer / Company"
							   Required="true"
							   RequiredError="Please select a customer"
							   Variant="Variant.Outlined"
							   AnchorOrigin="Origin.BottomCenter"
							   @bind-Value="Conversation.CompanyId">

						<MudSelectItem Value="@(Guid.Empty)">-- Select a Customer --</MudSelectItem>

						@foreach (var Customer in Customers)
						{
							<MudSelectItem Value="@Customer.CompanyId">@Customer.Name</MudSelectItem>
						}

						@* Vaste nep-ID's om de oneindige loop te voorkomen! *@
						<MudSelectItem Value="@(new Guid("11111111-1111-1111-1111-111111111111"))">Klant A (Demo)</MudSelectItem>
						<MudSelectItem Value="@(new Guid("22222222-2222-2222-2222-222222222222"))">Klant B (Demo)</MudSelectItem>
					</MudSelect>

					<div class="d-flex justify-end mt-1">
						<MudButton Variant="Variant.Text"
								   Color="Color.Primary"
								   StartIcon="@Icons.Material.Filled.Add"
								   Size="Size.Small"
								   OnClick="OpenCreateCustomerDialog">
							Create new customer
						</MudButton>
					</div>
				</MudItem>

				@* 3. Datum en Tijd *@
				<MudItem xs="12" sm="6">
					<MudDatePicker Label="Meeting Date"
								   @bind-Date="SelectedDate"
								   Variant="Variant.Outlined"
								   Editable="true" />
				</MudItem>
				<MudItem xs="12" sm="6">
					<MudTimePicker Label="Meeting Time"
								   @bind-Time="SelectedTime"
								   Variant="Variant.Outlined"
								   Editable="true" />
				</MudItem>

				@* 4. Medewerker (Read-only, want jij bent het) *@
				<MudItem xs="12">
					<MudTextField T="string"
								  Label="Sales Employee"
								  ReadOnly="true"
								  Value="@UserProfile?.FullName"
								  Variant="Variant.Outlined"
								  Adornment="Adornment.Start"
								  AdornmentIcon="@Icons.Material.Filled.Person" />
				</MudItem>

				@* Actie Knoppen *@
				<MudItem xs="12" Class="d-flex justify-end mt-4">
					<MudButton Variant="Variant.Text"
							   Color="Color.Secondary"
							   OnClick="NavigateBack"
							   Class="mr-2">
						Cancel
					</MudButton>
					<MudButton Variant="Variant.Filled"
							   Color="Color.Primary"
							   OnClick="HandleSave"
							   Disabled="@(!IsFormValid || IsSaving)"
							   Size="Size.Large">
						@if (IsSaving)
						{
							<MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
							<MudText Class="ms-2">Saving...</MudText>
						}
						else
						{
							<MudText>Save & Prepare</MudText>
						}
					</MudButton>
				</MudItem>

			</MudGrid>
		</MudForm>
	</MudPaper>
</MudContainer>

@code {
	[SupplyParameterFromQuery(Name = "companyId")]
	public Guid? PreselectedCompanyId { get; set; }

	[CascadingParameter]
	public UserProfileDto UserProfile { get; set; } = new();
	private bool IsSaving;
	private MudForm Form;
	private bool IsFormValid;

	private List<CompanyNames> Customers = new List<CompanyNames>();
	private CreateConversationDto Conversation = new();
	private CancellationTokenSource TokenSource { get; set; } = new();

	private DateTime? SelectedDate = DateTime.Today;
	private TimeSpan? SelectedTime = DateTime.Now.TimeOfDay;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			await GetCompanies();

			if (UserProfile != null && UserProfile.UserId.HasValue)
			{
				Conversation.SalesUserId = UserProfile.UserId.Value;
			}
		}
		catch (Exception Ex)
		{
			Console.WriteLine($"Crash while loading page: {Ex.Message}");
		}
	}

	private void NavigateBack()
	{
		if (PreselectedCompanyId.HasValue && PreselectedCompanyId.Value != Guid.Empty)
		{
			NavManager.NavigateTo($"/SalesConversation/{PreselectedCompanyId.Value}");
			return;
		}

		NavManager.NavigateTo("/SalesConversation/");
	}

	private async Task GetCompanies()
	{
		Customers = await CompanyService.GetCompanyNamesAsync(TokenSource.Token);

		if (PreselectedCompanyId.HasValue && PreselectedCompanyId.Value != Guid.Empty)
		{
			var companyExists = Customers.Any(c => c.CompanyId == PreselectedCompanyId.Value);
			if (companyExists)
			{
				Conversation.CompanyId = PreselectedCompanyId.Value;
			}
		}
	}

	private async Task HandleSave()
	{
		if (IsFormValid)
		{
			try
			{
				IsSaving = true;

				if (SelectedDate.HasValue && SelectedTime.HasValue)
				{
					Conversation.MeetingDate = SelectedDate.Value.Add(SelectedTime.Value);
				}

				var Result = await ConversationService.CreateConversationAsync(Conversation, TokenSource.Token);

				if (Result.ConversationId != Guid.Empty)
				{
					Snackbar.Add("Conversation has been prepared successfully!", Severity.Success);
					NavManager.NavigateTo($"/SalesConversation/Detail/{Result.ConversationId}");
				}
			}
			catch (TaskCanceledException)
			{
				Console.WriteLine("Saving was canceled (for example due to timeout or navigation).");
				Snackbar.Add("Saving took too long or was canceled.", Severity.Warning);
			}
			catch (Exception Ex)
			{
				Console.WriteLine($"Error while saving: {Ex.Message}");
				Snackbar.Add("Something went wrong while creating the conversation.", Severity.Error);
			}
			finally
			{
				IsSaving = false;
			}

		}
	}

	private async Task OpenCreateCustomerDialog()
	{
		var Options = new DialogOptions
		{
			CloseOnEscapeKey = true,
			MaxWidth = MaxWidth.Small,
			FullWidth = true,
			BackdropClick = true
		};

		var Dialog = await DialogService.ShowAsync<CreateCustomerDialog>("Add New Customer", Options);
		var Result = await Dialog.Result;

		if (!Result.Canceled && Result.Data is true)
		{
			await GetCompanies();

			StateHasChanged();

			Snackbar.Add("New customer has been added!", Severity.Success);
		}
	}

	public void Dispose()
	{
		TokenSource.Cancel();
		TokenSource.Dispose();
	}
}
