@page "/SalesConversation/TeamActionPoints"
@using MudBlazor
@using ActivityAssistent.Shared.Dtos.ActionPoints
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.App.Interfaces.ActionPoint
@using ActivityAssistent.App.Interfaces.Conversations
@inject IActionPointService ActionPointService
@inject IConversationService ConversationService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager NavManager
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
	<MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
		<MudItem>
			<MudText Typo="Typo.h4" Color="Color.Primary">Team action points</MudText>
			<MudText Typo="Typo.body2" Color="Color.Secondary">
				Overview of the team's tasks and statuses.
			</MudText>
		</MudItem>
		<MudItem>
			<MudStack Row="true" Spacing="2">
				<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
					New team action point
				</MudButton>
				<MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="NavigateBack">
					Back to conversations
				</MudButton>
			</MudStack>
		</MudItem>
	</MudGrid>

	<MudPaper Elevation="2">
		@if (IsLoading)
		{
			<div class="d-flex justify-center align-center pa-12">
				<MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
				<MudText Class="ml-4">Loading action points...</MudText>
			</div>
		}
		else
		{
			<MudTable Items="ActionPointItems" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0">
				<HeaderContent>
					<MudTh>Conversation</MudTh>
					<MudTh>Description</MudTh>
					<MudTh>Due date</MudTh>
					<MudTh>Status</MudTh>
					<MudTh>Employee</MudTh>
					<MudTh Style="text-align: right;">Actions</MudTh>
				</HeaderContent>
				<RowTemplate>
					<MudTd DataLabel="Conversation">@GetConversationTitle(context.ConversationId)</MudTd>
					<MudTd DataLabel="Description">@context.Description</MudTd>
					<MudTd DataLabel="Due date">@context.DueDate.ToString("dd-MM-yyyy")</MudTd>
					<MudTd DataLabel="Status">
						<MudChip T="string" Color="@(context.IsCompleted ? Color.Success : Color.Warning)" Size="Size.Small">
							@(context.IsCompleted ? "Completed" : "Open")
						</MudChip>
					</MudTd>
					<MudTd DataLabel="Employee">@GetUserName(context.SalesUserId)</MudTd>
					<MudTd DataLabel="Actions" Style="text-align: right;">
						<MudIconButton Icon="@Icons.Material.Filled.Done"
								 Color="Color.Success"
								 Size="Size.Small"
								 Title="Resolve"
								 OnClick="() => OpenResolveDialog(context)" />
						<MudIconButton Icon="@Icons.Material.Filled.History"
								 Color="Color.Info"
								 Size="Size.Small"
								 Title="Resolution history"
								 OnClick="() => OpenHistoryDialog(context)" />
						<MudIconButton Icon="@Icons.Material.Filled.Edit"
								 Color="Color.Primary"
								 Size="Size.Small"
								 OnClick="() => OpenEditDialog(context)" />
						<MudIconButton Icon="@Icons.Material.Filled.Delete"
								 Color="Color.Error"
								 Size="Size.Small"
								 OnClick="() => DeleteActionPoint(context)" />
					</MudTd>
				</RowTemplate>
				<NoRecordsContent>
					<MudText Class="pa-4">No action points found.</MudText>
				</NoRecordsContent>
			</MudTable>
		}
	</MudPaper>
</MudContainer>

@code {
	[CascadingParameter]
	public UserProfileDto? UserProfile { get; set; }

	private MudForm Form;
	private bool IsFormValid;
	private bool IsLoading;
	private bool IsSaving;
	private bool IsEditMode;
	private Guid? EditingActionPointId;
	private Guid SelectedConversationId;
	private Guid SelectedSalesUserId;
	private string Description = string.Empty;
	private DateTime? DueDate = DateTime.Today;
	private bool IsCompleted;
	private List<ActionPointDto> ActionPointItems = new();
	private List<ConversationDto> Conversations = new();
	private List<UserProfileDto> DelegationUsers = new();
	private CancellationTokenSource TokenSource { get; set; } = new();

	private string FormTitle => IsEditMode ? "Actiepunt bewerken" : "Nieuw teamactiepunt";
	private string FormButtonText => IsEditMode ? "Opslaan" : "Actiepunt toevoegen";

	protected override async Task OnInitializedAsync()
	{
		await LoadDelegationUsersAsync();
		await LoadConversationsAsync();
		await LoadActionPointsAsync();
	}

	private async Task LoadDelegationUsersAsync()
	{
		try
		{
			var result = await ActionPointService.GetDelegationUsersAsync(TokenSource.Token);
			DelegationUsers = result ?? new List<UserProfileDto>();
			if (UserProfile?.UserId != null && !DelegationUsers.Any(x => x.UserId == UserProfile.UserId))
			{
				DelegationUsers.Insert(0, UserProfile);
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Fout bij laden medewerkers: {ex.Message}");
			Snackbar.Add("Error while loading co-workers.", Severity.Error);
		}
	}

	private async Task LoadConversationsAsync()
	{
		try
		{
			var result = await ConversationService.GetAllAsync(TokenSource.Token);
			Conversations = result?.ToList() ?? new List<ConversationDto>();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Fout bij laden gesprekken: {ex.Message}");
			Snackbar.Add("Error while loading conversations.", Severity.Error);
		}
	}

	private async Task LoadActionPointsAsync()
	{
		IsLoading = true;
		try
		{
			var userId = UserProfile?.UserId?.ToString() ?? string.Empty;
			var result = await ActionPointService.GetActiveActionPointsAsync(userId, TokenSource.Token);
			ActionPointItems = result?.ToList() ?? new List<ActionPointDto>();
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Fout bij laden actiepunten: {ex.Message}");
			Snackbar.Add("Error while loading action points.", Severity.Error);
		}
		finally
		{
			IsLoading = false;
		}
	}

	private async Task OpenCreateDialog()
	{
		var defaultConversationId = Conversations.FirstOrDefault()?.ConversationId ?? Guid.Empty;
		var dialogModel = new ActionPointDialogModel
		{
			Description = string.Empty,
			DueDate = DateTime.Today,
			IsCompleted = false,
			SelectedSalesUserId = UserProfile?.UserId ?? Guid.Empty
		};

		await OpenActionPointDialogAsync(dialogModel, defaultConversationId, null);
	}

	private async Task OpenEditDialog(ActionPointDto actionPoint)
	{
		var dialogModel = new ActionPointDialogModel
		{
			Description = actionPoint.Description,
			DueDate = actionPoint.DueDate,
			IsCompleted = actionPoint.IsCompleted,
			SelectedSalesUserId = actionPoint.SalesUserId
		};

		await OpenActionPointDialogAsync(dialogModel, actionPoint.ConversationId, actionPoint);
	}

	private async Task OpenActionPointDialogAsync(ActionPointDialogModel model, Guid conversationId, ActionPointDto? existingActionPoint)
	{
		var parameters = new DialogParameters
		{
			["Model"] = model,
			["DelegationUsers"] = DelegationUsers,
			["Conversations"] = Conversations,
			["SelectedConversationId"] = conversationId
		};

		var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
		var title = existingActionPoint == null ? "New team action point" : "Edit team action point";
		var dialog = await DialogService.ShowAsync<global::ActivityAssistent.App.Components.Pages.SalesConversations.TeamActionPointDialog>(title, parameters, options);
		var result = await dialog.Result;

		if (result.Canceled || result.Data is not TeamActionPointDialogResult dialogResult)
		{
			return;
		}

		await SaveActionPointAsync(dialogResult, existingActionPoint?.ActionPointId);
	}

	private async Task SaveActionPointAsync(TeamActionPointDialogResult model, Guid? existingActionPointId)
	{
		try
		{
			if (model.ConversationId == Guid.Empty)
			{
				Snackbar.Add("Please select a conversation first.", Severity.Warning);
				return;
			}

			var salesUserId = model.ActionPoint.SelectedSalesUserId == Guid.Empty
				? UserProfile?.UserId ?? Guid.Empty
				: model.ActionPoint.SelectedSalesUserId;
			var subNrId = UserProfile?.SubNrId ?? Guid.Empty;
			var dueDate = model.ActionPoint.DueDate ?? DateTime.Today;

			if (existingActionPointId.HasValue)
			{
				var updateDto = new UpdateActionPointDto
				{
					ActionPointId = existingActionPointId.Value,
					ConversationId = model.ConversationId,
					Description = model.ActionPoint.Description,
					SalesUserId = salesUserId,
					DueDate = dueDate,
					IsCompleted = model.ActionPoint.IsCompleted,
					SubNrId = subNrId
				};

				var updated = await ActionPointService.UpdateActionPointAsync(updateDto, TokenSource.Token);
				if (updated.ActionPointId != Guid.Empty)
				{
					await LoadActionPointsAsync();
				}
				Snackbar.Add("Action point updated.", Severity.Success);
			}
			else
			{
				var createDto = new CreateActionPointDto
				{
					ConversationId = model.ConversationId,
					Description = model.ActionPoint.Description,
					SalesUserId = salesUserId,
					DueDate = dueDate,
					IsCompleted = model.ActionPoint.IsCompleted,
					SubNrId = subNrId
				};

				var created = await ActionPointService.CreateActionPointAsync(createDto, TokenSource.Token);
				if (created.ActionPointId != Guid.Empty)
				{
					await LoadActionPointsAsync();
					Snackbar.Add("Action point added.", Severity.Success);
				}
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Fout bij opslaan actiepunt: {ex.Message}");
			Snackbar.Add("Error while saving action point.", Severity.Error);
		}
	}

	private async Task OpenResolveDialog(ActionPointDto actionPoint)
	{
		var parameters = new DialogParameters
		{
			["Model"] = new CreateActionPointResolutionDto { ActionPointId = actionPoint.ActionPointId }
		};

		var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
			var dialog = await DialogService.ShowAsync<ActionPointResolutionDialog>("Resolve action point", parameters, options);
		var result = await dialog.Result;

		if (result.Canceled || result.Data is not CreateActionPointResolutionDto resolution)
		{
			return;
		}

		try
		{
			var created = await ActionPointService.ResolveActionPointAsync(resolution, TokenSource.Token);
			if (created.ResolutionId != Guid.Empty)
			{
				await LoadActionPointsAsync();
				Snackbar.Add("Action point resolved.", Severity.Success);
			}
			else
			{
				Snackbar.Add("Action point could not be resolved.", Severity.Warning);
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error while resolving action point: {ex.Message}");
			Snackbar.Add("Error while resolving action point.", Severity.Error);
		}
	}

	private async Task DeleteActionPoint(ActionPointDto actionPoint)
	{
		try
		{
			var result = await ActionPointService.DeleteActionPointAsync(actionPoint.ActionPointId, TokenSource.Token);
			if (result)
			{
				ActionPointItems.Remove(actionPoint);
				Snackbar.Add("Action point deleted.", Severity.Success);
			}
			else
			{
				Snackbar.Add("Action point could not be deleted.", Severity.Warning);
			}
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Error while deleting action point: {ex.Message}");
			Snackbar.Add("Error while deleting action point.", Severity.Error);
		}
	}

	private async Task OpenHistoryDialog(ActionPointDto actionPoint)
	{
		var parameters = new DialogParameters
		{
			["ActionPointId"] = actionPoint.ActionPointId
		};

		var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
		await DialogService.ShowAsync<global::ActivityAssistent.App.Components.Pages.SalesConversations.ActionPointResolutionHistoryDialog>("Resolution history", parameters, options);
	}


	private string GetConversationTitle(Guid conversationId)
	{
		var match = Conversations.FirstOrDefault(x => x.ConversationId == conversationId);
		return match?.Title ?? conversationId.ToString();
	}

	private string GetUserName(Guid userId)
	{
		var user = DelegationUsers.FirstOrDefault(x => x.UserId == userId);
		return user?.FullName ?? userId.ToString();
	}

	private void NavigateBack()
	{
		NavManager.NavigateTo("/SalesConversation/");
	}

	public void Dispose()
	{
		TokenSource.Cancel();
		TokenSource.Dispose();
	}
}
