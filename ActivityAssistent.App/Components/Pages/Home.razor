@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ActivityAssistent.App.Auth
@using ActivityAssistent.Shared.Dtos.ActionPoints
@using ActivityAssistent.Shared.Dtos.Conversations
@using ActivityAssistent.Shared.Dtos.Identity
@using ActivityAssistent.Shared.Enums
@using ActivityAssistent.App.Interfaces.ActionPoint
@using ActivityAssistent.App.Interfaces.Conversations
@inject CustomAuthenticationStateProvider AuthStateProvider
@inject IActionPointService ActionPointService
@inject IConversationService ConversationService
@inject NavigationManager NavManager
@inject ISnackbar Snackbar
@using MudBlazor

<PageTitle>Dashboard - ActivityAssistent</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">
	<AuthorizeView>
		<Authorized>
			<MudGrid Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
				<MudItem>
			<MudText Typo="Typo.h3" GutterBottom="true">Sales Dashboard</MudText>
			<MudText Typo="Typo.body2" Color="Color.Default">
				Overview of your conversations and action points.
			</MudText>
				</MudItem>
				<MudItem>
			<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Handshake" OnClick="NavigateToConversations">
				View conversations
			</MudButton>
					
				</MudItem>
			</MudGrid>

			<MudGrid Class="mb-6">
		<MudItem xs="12" sm="6" md="4">
			<MudCard Elevation="4" Class="rounded-lg">
				<MudCardHeader>
					<CardHeaderContent>
					<MudText Typo="Typo.h6">Welcome back</MudText>
						<MudText Typo="Typo.subtitle1" Color="Color.Primary">@UserProfile.FullName</MudText>
					</CardHeaderContent>
					<CardHeaderActions>
						<MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Default" />
					</CardHeaderActions>
				</MudCardHeader>
				<MudCardContent>
					<MudText Typo="Typo.body2">Your personal overview is up to date.</MudText>
				</MudCardContent>
			</MudCard>
		</MudItem>
		<MudItem xs="12" sm="6" md="4">
			<MudCard Elevation="4" Class="rounded-lg">
				<MudCardHeader>
					<CardHeaderContent>
					<MudText Typo="Typo.h6">Open action points</MudText>
						<MudText Typo="Typo.h4" Color="Color.Warning">@OpenActionPointsCount</MudText>
					</CardHeaderContent>
					<CardHeaderActions>
						<MudIcon Icon="@Icons.Material.Filled.ListAlt" Color="Color.Warning" />
					</CardHeaderActions>
				</MudCardHeader>
				<MudCardContent>
					<MudText Typo="Typo.body2">Action points that still need attention.</MudText>
				</MudCardContent>
			</MudCard>
		</MudItem>
		<MudItem xs="12" sm="6" md="4">
			<MudCard Elevation="4" Class="rounded-lg">
				<MudCardHeader>
					<CardHeaderContent>
					<MudText Typo="Typo.h6">Scheduled meetings</MudText>
						<MudText Typo="Typo.h4" Color="Color.Info">@ScheduledConversationsCount</MudText>
					</CardHeaderContent>
					<CardHeaderActions>
						<MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Info" />
					</CardHeaderActions>
				</MudCardHeader>
				<MudCardContent>
					<MudText Typo="Typo.body2">Upcoming meetings for your agenda.</MudText>
				</MudCardContent>
			</MudCard>
		</MudItem>
			</MudGrid>

			<MudGrid>
		<MudItem xs="12" md="7">
			<MudPaper Elevation="2" Class="pa-4">
				<MudText Typo="Typo.h6" Class="mb-2">Priority action points</MudText>
				<MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
					Next action points based on due date.
				</MudText>

				@if (IsLoading)
				{
					<MudStack Spacing="2">
						<MudSkeleton Height="24px" Width="40%" />
						<MudSkeleton Height="18px" Width="70%" />
						<MudSkeleton Height="18px" Width="60%" />
						<MudSkeleton Height="18px" Width="50%" />
					</MudStack>
				}
				else if (!PriorityActionPoints.Any())
				{
					<MudStack AlignItems="AlignItems.Center" Spacing="1" Class="py-4">
						<MudIcon Icon="@Icons.Material.Filled.TaskAlt" Size="Size.Large" Color="Color.Success" />
						<MudText>No open action points found.</MudText>
					</MudStack>
				}
				else
				{
					<MudList T="ActionPointDto" Dense="true">
						@foreach (var actionPoint in PriorityActionPoints)
						{
							<MudListItem T="ActionPointDto" OnClick="() => NavigateToConversation(actionPoint.ConversationId)" Style="cursor: pointer;">
								<MudListItemText>
									<MudText Typo="Typo.subtitle2">@actionPoint.Description</MudText>
									<MudText Typo="Typo.caption" Color="Color.Default">Due @actionPoint.DueDate.ToString("dd-MM-yyyy")</MudText>
								</MudListItemText>
								<MudStack Row="true" Spacing="1">
									<MudChip T="string" Color="@(actionPoint.IsCompleted ? Color.Success : Color.Warning)" Size="Size.Small">
										@(actionPoint.IsCompleted ? "Completed" : "Open")
									</MudChip>
									@if (IsOverdue(actionPoint))
									{
										<MudChip T="string" Color="Color.Error" Size="Size.Small">Overdue</MudChip>
									}
								</MudStack>
							</MudListItem>
						}
					</MudList>
				}
			</MudPaper>
		</MudItem>

		<MudItem xs="12" md="5">
			<MudPaper Elevation="2" Class="pa-4">
			<MudText Typo="Typo.h6" Class="mb-2">Recent meetings</MudText>
			<MudText Typo="Typo.body2" Color="Color.Default" Class="mb-4">
				Latest meetings and their status.
			</MudText>

			<MudTextField T="string"
						 Label="Search meetings"
						 Variant="Variant.Outlined"
						 Adornment="Adornment.Start"
						 AdornmentIcon="@Icons.Material.Filled.Search"
						 Immediate="true"
						 Class="mb-4"
						 @bind-Value="ConversationFilter" />

				@if (IsLoading)
				{
					<MudStack Spacing="2">
						<MudSkeleton Height="24px" Width="50%" />
						<MudSkeleton Height="18px" Width="80%" />
						<MudSkeleton Height="18px" Width="70%" />
						<MudSkeleton Height="18px" Width="60%" />
					</MudStack>
				}
				else if (!RecentConversations.Any())
				{
					<MudStack AlignItems="AlignItems.Center" Spacing="1" Class="py-4">
						<MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" />
						<MudText>No meetings found.</MudText>
					</MudStack>
				}
				else
				{
					<MudList T="ConversationDto" Dense="true">
						@foreach (var conversation in RecentConversations)
						{
							<MudListItem T="ConversationDto" OnClick="() => NavigateToConversation(conversation.ConversationId)" Style="cursor: pointer;">
								<MudListItemText>
									<MudText Typo="Typo.subtitle2">@conversation.Title</MudText>
									<MudText Typo="Typo.caption" Color="Color.Default">@conversation.MeetingDate.ToString("dd-MM-yyyy HH:mm")</MudText>
								</MudListItemText>
								<MudChip T="string" Color="GetStatusColor(conversation.Status)" Size="Size.Small">
									@conversation.Status.ToString()
								</MudChip>
							</MudListItem>
						}
					</MudList>
				}
			</MudPaper>
		</MudItem>
			</MudGrid>
		</Authorized>
		<NotAuthorized>
			<MudPaper Elevation="2" Class="pa-8 d-flex flex-column align-center justify-center">
				<MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
				<MudText Typo="Typo.h5" Class="mb-2">Welcome to ActivityAssistent</MudText>
				<MudText Typo="Typo.body1" Color="Color.Default" Align="Align.Center" Class="mb-4">
					Sign in to view your conversations, action points, and AI summaries.
				</MudText>
				<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Login" OnClick="NavigateToLogin">
					Go to login
				</MudButton>
			</MudPaper>
		</NotAuthorized>
	</AuthorizeView>
</MudContainer>

@code {
	[CascadingParameter]
	public UserProfileDto UserProfile { get; set; } = new();

	private bool IsLoading { get; set; }
	private List<ActionPointDto> ActionPoints { get; set; } = new();
	private List<ConversationDto> Conversations { get; set; } = new();
	private CancellationTokenSource TokenSource { get; set; } = new();

	private int OpenActionPointsCount => ActionPoints.Count(x => !x.IsCompleted);
	private int ScheduledConversationsCount => Conversations.Count(x => x.Status == ConversationStatus.Scheduled);
	private IEnumerable<ActionPointDto> PriorityActionPoints => ActionPoints
		.Where(x => !x.IsCompleted)
		.OrderBy(x => x.DueDate)
		.Take(5);
	private string ConversationFilter { get; set; } = string.Empty;

	private IEnumerable<ConversationDto> RecentConversations => Conversations
		.Where(x => string.IsNullOrWhiteSpace(ConversationFilter)
			|| (!string.IsNullOrWhiteSpace(x.Title)
				&& x.Title.Contains(ConversationFilter, StringComparison.OrdinalIgnoreCase)))
		.OrderByDescending(x => x.MeetingDate)
		.Take(5);

	private bool HasLoaded;

	protected override async Task OnParametersSetAsync()
	{
		if (UserProfile?.UserId is null || HasLoaded)
		{
			return;
		}

		HasLoaded = true;
		await LoadDashboardAsync();
	}

	private async Task LoadDashboardAsync()
	{
		IsLoading = true;
		try
		{
			if (UserProfile?.UserId is null)
			{
				return;
			}

			var userId = UserProfile.UserId.ToString();
			var actionPointsTask = ActionPointService.GetActiveActionPointsAsync(userId, TokenSource.Token);
			var conversationsTask = ConversationService.GetAllAsync(TokenSource.Token);

			await Task.WhenAll(actionPointsTask, conversationsTask);

			ActionPoints = actionPointsTask.Result?.ToList() ?? new List<ActionPointDto>();
			Conversations = conversationsTask.Result?.ToList() ?? new List<ConversationDto>();
		}
		catch (Exception ex)
		{
		Console.WriteLine($"Error loading dashboard: {ex.Message}");
		Snackbar.Add("Failed to load the dashboard.", Severity.Error);
		}
		finally
		{
			IsLoading = false;
		}
	}

	private void NavigateToConversations()
	{
		NavManager.NavigateTo("/SalesConversation/");
	}

	// private void NavigateToSummaries()
	// {
	// 	NavManager.NavigateTo("/SalesConversation/Summaries");
	// }

	private void NavigateToConversation(Guid conversationId)
	{
		NavManager.NavigateTo($"/SalesConversation/Detail/{conversationId}");
	}

	private void NavigateToLogin()
	{
		NavManager.NavigateTo("/login");
	}

	private void LogoutAsync()
	{
		AuthStateProvider.LogOut();
		NavManager.NavigateTo("/login");
	}

	private bool IsOverdue(ActionPointDto actionPoint)
	{
		return !actionPoint.IsCompleted && actionPoint.DueDate.Date < DateTime.Today;
	}

	private Color GetStatusColor(ConversationStatus Status)
	{
		return Status switch
		{
			ConversationStatus.Scheduled => Color.Info,
			ConversationStatus.Recording => Color.Secondary,
			ConversationStatus.Processing => Color.Warning,
			ConversationStatus.Completed => Color.Success,
			ConversationStatus.Failed => Color.Error,
			_ => Color.Default
		};
	}

	public void Dispose()
	{
		TokenSource.Cancel();
		TokenSource.Dispose();
	}
}
